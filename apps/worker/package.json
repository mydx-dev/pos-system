{
    "name": "@mydx-pos/worker",
    "private": true,
    "type": "module",
    "dependencies": {
        "@mydx-pos/shared": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^6.0.3",
        "wrangler": "^4.49.0"
    },
    "scripts": {
        "dev": "wrangler dev",
        "build": "wrangler deploy --dry-run",
        "test": "vitest --run",
        "typecheck": "tsc --noEmit",
        "check": "pnpm typecheck && pnpm build",
        "db:migrations:list": "wrangler d1 migrations list mydx-pos-local",
        "db:migrations:apply:local": "wrangler d1 migrations apply mydx-pos-local --local",
        "types": "wrangler types"
    }
}

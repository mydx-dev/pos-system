{
    "compilerOptions": {
        "target": "ES2021",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "ignoreDeprecations": "6.0",
        "strict": true,
        "esModuleInterop": true,
        "allowJs": true,
        "sourceMap": false,
        "skipLibCheck": true,
        "lib": ["ES2021", "DOM"],
        "jsx": "react-jsx"
    }
}
